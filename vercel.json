{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "lib/**"
    }
  },
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": { "includeFiles": "lib/**" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
